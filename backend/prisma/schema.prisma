// Schéma Prisma pour NASS-OPTIMANAGE
// Application de gestion multi-boutiques d'optique (multi-tenant)
// Chaque enregistrement est isolé par tenantId pour séparer les données entre boutiques

// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =========================
// ENUMS
// =========================

// Moyens de règlement acceptés lors d'un paiement
enum MethodePaiement {
  ESPECES
  CARTE
  MOBILE_MONEY
  CHEQUE
}

// État de règlement d'une vente
enum StatutPaiement {
  PAYE
  PARTIEL
  IMPAYE
}

// Niveaux d'accès des utilisateurs dans la boutique
enum Role {
  SUPER_ADMIN // Accès global (hors tenant)
  ADMIN // Gestion complète de la boutique
  VENDEUR // Création de ventes et devis
  MONTEUR // Gestion des commandes atelier
}

// Catégories de produits en stock
enum TypeProduit {
  MONTURE
  VERRE
  LENTILLE
  ACCESSOIRE
}

// Cycle de vie d'une commande en atelier
enum StatutAtelier {
  COMMANDE_PASSEE
  EN_COURS
  TERMINE
  PRODUIT_PRET
}

// Cycle de vie d'un devis commercial
enum StatutDevis {
  BROUILLON
  ENVOYE
  ACCEPTE
  REFUSE
  EXPIRE
}

// Types de corrections optiques possibles
enum TypeVerre {
  UNIFOCAL
  BIFOCAL
  PROGRESSIF
  LENTILLE_CONTACT
}

// État de traitement d'une demande de retour produit
enum StatutRetour {
  EN_ATTENTE
  APPROUVE
  REFUSE
  REMBOURSE
}

// Types d'événements tracés dans l'historique d'audit
enum TypeAction {
  CREATION
  MODIFICATION
  SUPPRESSION
  CONNEXION
  DECONNEXION
  CHANGEMENT_STATUT
}

// Direction d'un mouvement de stock
enum TypeMouvement {
  ENTREE // Réception fournisseur ou retour approuvé
  SORTIE // Vente ou perte
  AJUSTEMENT // Correction manuelle d'inventaire
}

// =========================
// TENANT (BOUTIQUE)
// =========================

// Représente une boutique d'optique indépendante.
// Toutes les autres entités sont rattachées à un Tenant via tenantId.
model Tenant {
  id       Int    @id @default(autoincrement())
  // Identifiant public UUID utilisé dans les relations inter-tables
  tenantId String @unique @default(uuid())

  nomBoutique String
  adresse     String
  telephone   String
  createdAt   DateTime @default(now())

  // Relations
  utilisateurs Utilisateur[]
  patients     Patient[]
  fournisseurs Fournisseur[]
  produits     Produit[]
  ventes       Vente[]
  commandes    CommandeAtelier[]
  ordonnances  Ordonnance[]
  devis        Devis[]
  retours      Retour[]
  historiques  HistoriqueAction[]
  mouvements   MouvementStock[]
}

// =========================
// UTILISATEUR
// =========================

// Membre du personnel de la boutique avec un rôle métier.
// L'unicité [tenantId, email] permet le même email dans deux boutiques différentes.
model Utilisateur {
  id     Int    @id @default(autoincrement())
  userId String @unique @default(uuid())

  nom        String
  email      String
  motDePasse String // Stocké hashé (bcrypt)
  role       Role
  actif      Boolean  @default(true)
  createdAt  DateTime @default(now())

  // Relations
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade)

  ventes      Vente[]
  ordonnances Ordonnance[]
  devis       Devis[]
  retours     Retour[]
  paiements   Paiement[]
  historiques HistoriqueAction[]
  mouvements  MouvementStock[]

  @@unique([tenantId, email])
  @@index([userId])
}

// =========================
// PATIENT
// =========================

// Client porteur de lunettes ou lentilles suivi par la boutique.
// Les champs assurance permettent la prise en charge mutuelle.
model Patient {
  id        Int    @id @default(autoincrement())
  patientId String @unique @default(uuid())

  nomComplet      String
  telephone       String?
  profession      String?
  dateNaissance   DateTime?
  nomAssurance    String?
  numeroAssurance String?
  createdAt       DateTime  @default(now())

  // Relations
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade)

  ordonnances Ordonnance[]
  ventes      Vente[]
  devis       Devis[]

  @@index([tenantId])
}

// =========================
// ORDONNANCE
// =========================

// Prescription optique établie par un médecin pour un patient.
// OD = Oeil Droit, OG = Oeil Gauche (convention opticien).
// Une ordonnance peut déclencher plusieurs ventes et commandes atelier.
model Ordonnance {
  id           Int    @id @default(autoincrement())
  ordonnanceId String @unique @default(uuid())

  datePrescription DateTime?
  nomMedecin       String?

  // Paramètres de correction — Oeil Droit
  sphereOD          Decimal? // Correction de la myopie/hypermétropie
  cylindreOD        Decimal? // Correction de l'astigmatisme
  axeOD             Int? // Orientation du cylindre (0–180°)
  additionOD        Decimal? // Supplément pour presbytie (verres progressifs)
  ecartPupillaireOD Decimal? // Distance pupillaire (mm)

  // Paramètres de correction — Oeil Gauche
  sphereOG          Decimal?
  cylindreOG        Decimal?
  axeOG             Int?
  additionOG        Decimal?
  ecartPupillaireOG Decimal?

  // Relations
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade)

  // Utilisateur qui a saisi l'ordonnance (nullable car peut être supprimé)
  userId      String?
  utilisateur Utilisateur? @relation(fields: [userId], references: [userId], onDelete: SetNull)

  patientId String
  patient   Patient @relation(fields: [patientId], references: [patientId], onDelete: Cascade)

  ventes    Vente[]
  commandes CommandeAtelier[]

  @@index([ordonnanceId])
  @@index([tenantId])
  @@index([patientId])
  @@index([userId])
}

// =========================
// FOURNISSEUR
// =========================

// Fournisseur de produits (montures, verres, lentilles…) pour la boutique.
model Fournisseur {
  id            Int    @id @default(autoincrement())
  fournisseurId String @unique @default(uuid())
  tenantId      String

  nom     String
  contact String?

  tenant   Tenant    @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade)
  produits Produit[]

  @@index([tenantId])
}

// =========================
// PRODUIT
// =========================

// Article en stock. La référence est unique par boutique.
// prixAchat/prixVente permettent le calcul de la marge commerciale.
model Produit {
  id            Int     @id @default(autoincrement())
  produitId     String  @unique @default(uuid())
  tenantId      String
  fournisseurId String?

  reference String
  type      TypeProduit
  marque    String?

  prixAchat       Float
  prixVente       Float
  quantiteEnStock Int   @default(0)

  tenant      Tenant       @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade)
  // SetNull pour conserver le produit si le fournisseur est supprimé
  fournisseur Fournisseur? @relation(fields: [fournisseurId], references: [fournisseurId], onDelete: SetNull)

  lignesVente  LigneVente[]
  lignesDevis  LigneDevis[]
  lignesRetour LigneRetour[]
  mouvements   MouvementStock[]

  // Unicité de la référence au sein d'une boutique
  @@unique([tenantId, reference])
  @@index([tenantId])
  @@index([fournisseurId])
}

// =========================
// DEVIS
// =========================

// Proposition commerciale envoyée au patient avant validation en vente.
// Un devis accepté peut être converti en Vente (relation devis→vente 1:1).
model Devis {
  id      Int    @id @default(autoincrement())
  devisId String @unique @default(uuid())

  tenantId  String
  patientId String?
  userId    String

  dateCreation   DateTime  @default(now())
  dateExpiration DateTime? // Passée cette date, statut devient EXPIRE

  montantTotal Float
  remise       Float   @default(0)
  notes        String?

  statut StatutDevis

  tenant      Tenant      @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade)
  patient     Patient?    @relation(fields: [patientId], references: [patientId], onDelete: SetNull)
  utilisateur Utilisateur @relation(fields: [userId], references: [userId])

  lignes LigneDevis[]
  vente  Vente? // Renseigné quand le devis est converti en vente

  @@index([tenantId])
  @@index([patientId])
  @@index([userId])
}

// =========================
// LIGNE DEVIS
// =========================

// Détail d'un produit dans un devis (quantité + prix figé au moment de la création).
model LigneDevis {
  id           Int    @id @default(autoincrement())
  ligneDevisId String @unique @default(uuid())

  devisId   String
  produitId String

  quantite     Int
  prixUnitaire Float // Prix figé à la date du devis, indépendant du catalogue

  devis   Devis   @relation(fields: [devisId], references: [devisId], onDelete: Cascade)
  produit Produit @relation(fields: [produitId], references: [produitId])

  @@index([devisId])
  @@index([produitId])
}

// =========================
// VENTE
// =========================

// Transaction commerciale principale.
// resteAPayer est mis à jour à chaque paiement partiel enregistré.
// Une vente peut être liée à un devis converti et/ou à une ordonnance.
model Vente {
  id      Int    @id @default(autoincrement())
  venteId String @unique @default(uuid())

  tenantId     String
  userId       String
  patientId    String?
  ordonnanceId String?
  devisId      String? @unique // @unique car un devis ne peut générer qu'une vente

  dateCreation DateTime @default(now())

  montantTotal Float
  remise       Float @default(0)
  resteAPayer  Float @default(0) // Recalculé après chaque Paiement

  statut StatutPaiement

  tenant      Tenant      @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade)
  utilisateur Utilisateur @relation(fields: [userId], references: [userId])
  patient     Patient?    @relation(fields: [patientId], references: [patientId], onDelete: SetNull)
  ordonnance  Ordonnance? @relation(fields: [ordonnanceId], references: [ordonnanceId], onDelete: SetNull)
  devis       Devis?      @relation(fields: [devisId], references: [devisId], onDelete: SetNull)

  lignes          LigneVente[]
  paiements       Paiement[]
  commandeAtelier CommandeAtelier? // Commande en atelier associée (montage des verres)
  retours         Retour[]
  mouvements      MouvementStock[]

  @@index([tenantId])
  @@index([userId])
  @@index([patientId])
}

// =========================
// LIGNE VENTE
// =========================

// Détail d'un produit vendu (quantité + prix figé au moment de la vente).
model LigneVente {
  id           Int    @id @default(autoincrement())
  ligneVenteId String @unique @default(uuid())

  venteId   String
  produitId String

  quantite     Int
  prixUnitaire Float // Prix figé à la date de la vente

  vente   Vente   @relation(fields: [venteId], references: [venteId], onDelete: Cascade)
  produit Produit @relation(fields: [produitId], references: [produitId])

  @@index([venteId])
  @@index([produitId])
}

// =========================
// PAIEMENT
// =========================

// Encaissement partiel ou total d'une vente.
// Plusieurs paiements peuvent être rattachés à la même vente (règlement échelonné).
model Paiement {
  id         Int    @id @default(autoincrement())
  paiementId String @unique @default(uuid())

  venteId String
  userId  String? // Caissier ayant enregistré le paiement (nullable si supprimé)

  datePaiement DateTime        @default(now())
  montant      Float
  methode      MethodePaiement

  vente       Vente        @relation(fields: [venteId], references: [venteId], onDelete: Cascade)
  utilisateur Utilisateur? @relation(fields: [userId], references: [userId], onDelete: SetNull)

  @@index([venteId])
  @@index([userId])
}

// =========================
// COMMANDE ATELIER
// =========================

// Ordre de montage/taille des verres adressé à l'atelier optique.
// Liée à une vente (optionnel) et peut référencer une ordonnance directement.
// traitements[] liste les options de traitement (antireflet, antirayure…).
model CommandeAtelier {
  id         Int    @id @default(autoincrement())
  commandeId String @unique @default(uuid())

  tenantId     String
  venteId      String? @unique // Une vente ne génère qu'une commande atelier
  ordonnanceId String?

  dateCreation      DateTime      @default(now())
  statut            StatutAtelier
  dateExecutionJour DateTime? // Date prévue de finalisation

  typeVerre        TypeVerre?
  traitements      String[] // Ex: ["antireflet", "photochromique"]
  hauteurMontageOD Decimal? // Hauteur de centrage pupillaire (mm) OD
  hauteurMontageOG Decimal? // Hauteur de centrage pupillaire (mm) OG
  notes            String?

  tenant     Tenant      @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade)
  vente      Vente?      @relation(fields: [venteId], references: [venteId], onDelete: SetNull)
  ordonnance Ordonnance? @relation(fields: [ordonnanceId], references: [ordonnanceId], onDelete: SetNull)

  @@index([tenantId])
  @@index([ordonnanceId])
}

// =========================
// RETOUR
// =========================

// Demande de retour produit initiée par un patient après une vente.
// Restrict sur la vente : impossible de supprimer une vente ayant des retours.
model Retour {
  id       Int    @id @default(autoincrement())
  retourId String @unique @default(uuid())

  tenantId String
  venteId  String
  userId   String // Utilisateur ayant traité le retour

  dateRetour       DateTime     @default(now())
  motif            String?
  montantRembourse Float
  statut           StatutRetour

  tenant      Tenant      @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade)
  // Restrict : protège l'intégrité comptable — ne pas supprimer une vente remboursée
  vente       Vente       @relation(fields: [venteId], references: [venteId], onDelete: Restrict)
  utilisateur Utilisateur @relation(fields: [userId], references: [userId])

  lignes     LigneRetour[]
  mouvements MouvementStock[]

  @@index([tenantId])
  @@index([venteId])
  @@index([userId])
}

// =========================
// LIGNE RETOUR
// =========================

// Détail des produits retournés (peut être un sous-ensemble de la vente d'origine).
model LigneRetour {
  id            Int    @id @default(autoincrement())
  ligneRetourId String @unique @default(uuid())

  retourId  String
  produitId String

  quantite     Int
  prixUnitaire Float // Prix au moment de la vente d'origine (base de remboursement)

  retour  Retour  @relation(fields: [retourId], references: [retourId], onDelete: Cascade)
  produit Produit @relation(fields: [produitId], references: [produitId])

  @@index([retourId])
  @@index([produitId])
}

// =========================
// HISTORIQUE ACTION
// =========================

// Journal d'audit immuable de toutes les actions métier sensibles.
// anciennesValeurs / nouvellesValeurs stockent un diff JSON pour comparaison.
model HistoriqueAction {
  id           Int    @id @default(autoincrement())
  historiqueId String @unique @default(uuid())

  tenantId String
  userId   String? // Nullable : conserve la trace même si l'utilisateur est supprimé

  action   TypeAction
  modele   String // Nom du modèle Prisma affecté (ex: "Vente", "Produit")
  entiteId String // UUID de l'enregistrement affecté

  anciennesValeurs Json? // État avant modification (null pour CREATION)
  nouvellesValeurs Json? // État après modification (null pour SUPPRESSION)

  createdAt DateTime @default(now())

  tenant      Tenant       @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade)
  utilisateur Utilisateur? @relation(fields: [userId], references: [userId], onDelete: SetNull)

  @@index([tenantId])
  @@index([userId])
  @@index([modele, entiteId]) // Recherche rapide de l'historique d'un enregistrement
  @@index([createdAt])
}

// =========================
// MOUVEMENT STOCK
// =========================

// Trace chaque variation du stock d'un produit avec les quantités avant/après.
// quantiteAvant + quantite = quantiteApres (vérification d'intégrité possible).
model MouvementStock {
  id          Int    @id @default(autoincrement())
  mouvementId String @unique @default(uuid())

  tenantId  String
  produitId String
  userId    String? // Auteur du mouvement (nullable si utilisateur supprimé)
  venteId   String? // Renseigné si le mouvement provient d'une vente
  retourId  String? // Renseigné si le mouvement provient d'un retour approuvé

  type          TypeMouvement
  quantite      Int // Valeur absolue de la variation
  quantiteAvant Int // Stock avant ce mouvement
  quantiteApres Int // Stock après ce mouvement
  motif         String? // Précision libre (ex: "inventaire annuel")

  createdAt DateTime @default(now())

  tenant      Tenant       @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade)
  produit     Produit      @relation(fields: [produitId], references: [produitId])
  utilisateur Utilisateur? @relation(fields: [userId], references: [userId], onDelete: SetNull)
  vente       Vente?       @relation(fields: [venteId], references: [venteId], onDelete: SetNull)
  retour      Retour?      @relation(fields: [retourId], references: [retourId], onDelete: SetNull)

  @@index([tenantId])
  @@index([produitId])
  @@index([venteId])
  @@index([retourId])
  @@index([createdAt])
}
